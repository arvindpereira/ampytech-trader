# Secrets / environment (NEVER commit API keys)
.env
backend/.env
*.env

# Editor / agent / OS junk
*.un~
.claude/

# Dependencies
backend/venv/
frontend/node_modules/

# Local database & data
backend/data/*.db
!backend/data/trading_system.db

# Caches
pybroker_cache/
backend/pybroker_cache/
.next/
frontend/.next/
frontend/out/
__pycache__/
backend/__pycache__/
backend/*/__pycache__/
backend/*/*/__pycache__/
.pytest_cache/

# OS-specific files
.DS_Store
.DS_Store?
ehthumbs.db
Thumbs.db

# Saved Models (if you want to keep them local, or track them if needed - we'll ignore them to prevent binary bloat)
backend/ml_engine/saved_models/*.json
backend/ml_engine/saved_models/*.pkl
backend/ml_engine/saved_models/*.pth
backend/ml_engine/saved_models/_old_breakout_pth/

