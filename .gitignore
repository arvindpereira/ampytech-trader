# Secrets / environment (NEVER commit API keys)
.env
backend/.env
*.env

# Editor / agent / OS junk
*.un~
.claude/

# Dependencies
backend/venv/
backend/venv-py314/
backend/.security-venv/
backend/.security-venv-py314/
frontend/node_modules/

# Local database & data
# The trading DB is NO LONGER tracked in git/LFS (it churns at runtime and bloated LFS storage).
# Back it up with `make db-backup` (Google Drive, commit-stamped); restore with `make db-restore-commit`.
# History still holds the last snapshot at commit 313081e if ever needed.
backend/data/*.db
backend/data/*.db.bak-*
backend/data/*.db-wal
backend/data/*.db-shm
backend/data/scheduler_heartbeat.txt
backend/data/llm_pricing.json
backend/data/premium_ingest_state.json
backend/data/crash_forecast_state.json
backend/data/wargame_cache.json
backend/data/_equity_probe/


# Caches
backend/.make/
pybroker_cache/
backend/pybroker_cache/
.next/
frontend/.next/
frontend/out/
__pycache__/
backend/__pycache__/
backend/*/__pycache__/
backend/*/*/__pycache__/
.pytest_cache/

# OS-specific files
.DS_Store
.DS_Store?
ehthumbs.db
Thumbs.db

# Saved Models (if you want to keep them local, or track them if needed - we'll ignore them to prevent binary bloat)
backend/ml_engine/saved_models/*.json
backend/ml_engine/saved_models/*.pkl
backend/ml_engine/saved_models/*.pth
backend/ml_engine/saved_models/_old_breakout_pth/

# Premium News Archive
backend/data/premium_news/archive/

# Imported broker source files (financial PII) — backed up to Drive, never to git.
backend/data/import_sources/
backend/data/*.csv

# TS build info
*.tsbuildinfo
frontend/tsconfig.tsbuildinfo

# Google Drive OAuth token (do not commit)
backend/data/gdrive_token.json
backend/data/scheduler.pid
